####### Compile

main.o: main.cpp MainWindow.h \
		CompilerService.h \
		../symbols_table/SymbolsTableManager.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o main.o main.cpp

MainWindow.o: MainWindow.cpp MainWindow.h \
		CompilerService.h \
		../symbols_table/SymbolsTableManager.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o MainWindow.o MainWindow.cpp

CompilerService.o: CompilerService.cpp CompilerService.h \
		../symbols_table/SymbolsTableManager.h \
		../gals_code/LexicalError.h \
		../gals_code/AnalysisError.h \
		../gals_code/Lexico.h \
		../gals_code/Token.h \
		../gals_code/Constants.h \
		../gals_code/Semantico.h \
		../gals_code/SemanticError.h \
		../gals_code/Sintatico.h \
		../gals_code/SyntacticError.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o CompilerService.o CompilerService.cpp

Constants.o: ../gals_code/Constants.cpp ../gals_code/Constants.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o Constants.o ../gals_code/Constants.cpp

Lexico.o: ../gals_code/Lexico.cpp ../gals_code/Lexico.h \
		../gals_code/Token.h \
		../gals_code/Constants.h \
		../gals_code/LexicalError.h \
		../gals_code/AnalysisError.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o Lexico.o ../gals_code/Lexico.cpp

Sintatico.o: ../gals_code/Sintatico.cpp ../gals_code/Sintatico.h \
		../gals_code/Constants.h \
		../gals_code/Token.h \
		../gals_code/Lexico.h \
		../gals_code/LexicalError.h \
		../gals_code/AnalysisError.h \
		../gals_code/Semantico.h \
		../gals_code/SemanticError.h \
		../symbols_table/SymbolsTableManager.h \
		../gals_code/SyntacticError.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o Sintatico.o ../gals_code/Sintatico.cpp

Semantico.o: ../gals_code/Semantico.cpp ../gals_code/Semantico.h \
		../gals_code/Token.h \
		../gals_code/Constants.h \
		../gals_code/SemanticError.h \
		../gals_code/AnalysisError.h \
		../symbols_table/SymbolsTableManager.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o Semantico.o ../gals_code/Semantico.cpp

SymbolsTableManager.o: ../symbols_table/SymbolsTableManager.cpp ../symbols_table/SymbolsTableManager.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o SymbolsTableManager.o ../symbols_table/SymbolsTableManager.cpp

